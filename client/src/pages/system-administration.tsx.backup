                              <Badge className={`text-xs ${
                                task.status === 'success' ? 'bg-green-100 text-green-700' :
                                task.status === 'warning' ? 'bg-orange-100 text-orange-700' : 
                                task.status === 'pending' ? 'bg-blue-100 text-blue-700' : 'bg-red-100 text-red-700'
                              }`}>
                                {task.status === 'success' ? 'مكتمل' :
