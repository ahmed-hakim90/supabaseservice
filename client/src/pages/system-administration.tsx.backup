                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">النجاح</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">الأخطاء</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">متوسط الزمن</th>
                        </tr>
                      </thead>
                      <tbody>
                        {apiStats?.endpoints?.map((endpoint: any, index: number) => (
                          <tr key={index} className="hover:bg-gray-50 dark:hover:bg-gray-800">
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 font-mono text-sm">{endpoint.path}</td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">{endpoint.requests?.toLocaleString()}</td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center text-green-600">{endpoint.success?.toLocaleString()}</td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center text-red-600">{endpoint.errors}</td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">{endpoint.avgTime}</td>
                          </tr>
                        )) || []}
                      </tbody>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </CardContent>
              </Card>
            </div>

            {/* Error Monitoring */}
            <div className="space-y-6">
              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-exclamation-triangle"></i>
                    الأخطاء الأخيرة
                  </CardTitle>
                </CardHeader>
                <CardContent className="space-y-3">
                  {(apiStats?.recentErrors || []).map((error: any, index: number) => (
                    <div key={index} className="flex items-center justify-between p-3 bg-red-50 dark:bg-red-900/20 rounded-lg">
                      <div>
                        <div className="font-medium text-sm">{error.code} - {error.endpoint}</div>
                        <div className="text-xs text-muted-foreground">
                          {error.time ? formatDistanceToNow(new Date(error.time), { addSuffix: true, locale: ar }) : 'غير محدد'}
                        </div>
                      </div>
                      <Badge variant="destructive">{error.count}</Badge>
                    </div>
                  ))}
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-lightning"></i>
                    أداء النظام
                  </CardTitle>
                </CardHeader>
                <CardContent className="space-y-4">
                  <div className="space-y-2">
                    <div className="flex justify-between text-sm">
                      <span>زمن الاستجابة</span>
                      <span className="text-green-600">245ms</span>
                    </div>
                    <div className="w-full bg-gray-200 rounded-full h-2 dark:bg-gray-700">
                      <div className="bg-green-600 h-2 rounded-full" style={{ width: '75%' }}></div>
                    </div>
                  </div>
                  <div className="space-y-2">
                    <div className="flex justify-between text-sm">
                      <span>معدل الطلبات/ثانية</span>
                      <span className="text-blue-600">127</span>
                    </div>
                    <div className="w-full bg-gray-200 rounded-full h-2 dark:bg-gray-700">
                      <div className="bg-blue-600 h-2 rounded-full" style={{ width: '60%' }}></div>
                    </div>
                  </div>
                  <div className="space-y-2">
                    <div className="flex justify-between text-sm">
                      <span>استخدام الـ CPU</span>
                      <span className="text-yellow-600">{systemStats.cpuUsage}%</span>
                    </div>
                    <div className="w-full bg-gray-200 rounded-full h-2 dark:bg-gray-700">
                      <div className="bg-yellow-600 h-2 rounded-full" style={{ width: `${systemStats.cpuUsage}%` }}></div>
                    </div>
                  </div>
                </CardContent>
              </Card>
            </div>
          </div>
        </TabsContent>

        {/* User Activity Tab */}
        <TabsContent value="activity" className="space-y-6 mt-6">
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
            {/* Active Sessions */}
            <div className="lg:col-span-2 space-y-6">
              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-people"></i>
                    الجلسات النشطة
                  </CardTitle>
                  <CardDescription>المستخدمون المتصلون حاليًا</CardDescription>
                </CardHeader>
                <CardContent>
                  <div className="overflow-x-auto">
                    <table className="w-full border-collapse border border-gray-200 dark:border-gray-700">
                      <thead>
                        <tr className="bg-gray-50 dark:bg-gray-800">
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-right">المستخدم</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">الدور</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">وقت الدخول</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">النشاط</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">الموقع</th>
                        </tr>
                      </thead>
                      <tbody>
                        {[
                          { name: 'أحمد محمد', role: 'مدير', loginTime: 'منذ ساعتين', activity: 'تصفح التقارير', location: 'الرياض' },
                          { name: 'فاطمة علي', role: 'موظف', loginTime: 'منذ 30 دقيقة', activity: 'إدارة المخزون', location: 'جدة' },
                          { name: 'محمد سالم', role: 'موظف', loginTime: 'منذ 15 دقيقة', activity: 'معالجة الطلبات', location: 'الدمام' },
                          { name: 'نورا أحمد', role: 'مشرف', loginTime: 'منذ ساعة', activity: 'مراجعة البيانات', location: 'المدينة' },
                          { name: 'خالد يوسف', role: 'موظف', loginTime: 'منذ 10 دقائق', activity: 'إدخال بيانات', location: 'الطائف' }
                        ].map((user, index) => (
                          <tr key={index} className="hover:bg-gray-50 dark:hover:bg-gray-800">
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2">
                              <div className="flex items-center gap-2">
                                <div className="w-2 h-2 bg-green-500 rounded-full"></div>
                                {user.name}
                              </div>
                            </td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">
                              <Badge variant="outline">{user.role}</Badge>
                            </td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">{user.loginTime}</td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">{user.activity}</td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">{user.location}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-clock-history"></i>
                    سجل تسجيل الدخول الأخير
                  </CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="space-y-3">
                    {[
                      { user: 'سارة محمد', time: 'منذ 2 دقيقة', status: 'نجح', ip: '192.168.1.102' },
                      { user: 'علي أحمد', time: 'منذ 5 دقائق', status: 'نجح', ip: '192.168.1.105' },
                      { user: 'مجهول', time: 'منذ 8 دقائق', status: 'فشل', ip: '192.168.1.200' },
                      { user: 'فهد سالم', time: 'منذ 12 دقيقة', status: 'نجح', ip: '192.168.1.108' },
                      { user: 'مريم علي', time: 'منذ 15 دقيقة', status: 'نجح', ip: '192.168.1.110' }
                    ].map((login, index) => (
                      <div key={index} className="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
                        <div className="flex items-center gap-3">
                          <i className={`bi ${login.status === 'نجح' ? 'bi-check-circle text-green-600' : 'bi-x-circle text-red-600'}`}></i>
                          <div>
                            <div className="font-medium">{login.user}</div>
                            <div className="text-sm text-muted-foreground">{login.ip}</div>
                          </div>
                        </div>
                        <div className="text-sm text-muted-foreground">{login.time}</div>
                      </div>
                    ))}
                  </div>
                </CardContent>
              </Card>
            </div>

            {/* Activity Statistics */}
            <div className="space-y-6">
              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-bar-chart"></i>
                    إحصائيات النشاط
                  </CardTitle>
                </CardHeader>
                <CardContent className="space-y-4">
                  <div className="text-center p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
                    <div className="text-2xl font-bold text-blue-600">{systemStats.activeUsers}</div>
                    <div className="text-sm text-muted-foreground">مستخدم نشط</div>
                  </div>
                  <div className="text-center p-4 bg-green-50 dark:bg-green-900/20 rounded-lg">
                    <div className="text-2xl font-bold text-green-600">{systemStats.totalUsers}</div>
                    <div className="text-sm text-muted-foreground">إجمالي المستخدمين</div>
                  </div>
                  <div className="text-center p-4 bg-purple-50 dark:bg-purple-900/20 rounded-lg">
                    <div className="text-2xl font-bold text-purple-600">47</div>
                    <div className="text-sm text-muted-foreground">تسجيل دخول اليوم</div>
                  </div>
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-shield-check"></i>
                    الأدوار النشطة
                  </CardTitle>
                </CardHeader>
                <CardContent className="space-y-3">
                  {[
                    { role: 'مدير', count: 2, color: 'bg-red-100 text-red-800' },
                    { role: 'مشرف', count: 3, color: 'bg-yellow-100 text-yellow-800' },
                    { role: 'موظف', count: 12, color: 'bg-blue-100 text-blue-800' },
                    { role: 'عامل', count: 8, color: 'bg-green-100 text-green-800' }
                  ].map((role, index) => (
                    <div key={index} className="flex items-center justify-between">
                      <span className="text-sm">{role.role}</span>
                      <Badge variant="secondary" className={role.color}>
                        {role.count}
                      </Badge>
                    </div>
                  ))}
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-geo-alt"></i>
                    المواقع النشطة
                  </CardTitle>
                </CardHeader>
                <CardContent className="space-y-3">
                  {[
                    { location: 'الرياض', count: 5 },
                    { location: 'جدة', count: 3 },
                    { location: 'الدمام', count: 2 },
                    { location: 'المدينة', count: 1 },
                    { location: 'الطائف', count: 1 }
                  ].map((location, index) => (
                    <div key={index} className="flex items-center justify-between">
                      <span className="text-sm">{location.location}</span>
                      <span className="text-sm font-medium">{location.count}</span>
                    </div>
                  ))}
                </CardContent>
              </Card>
            </div>
          </div>
        </TabsContent>

        {/* Maintenance Tab */}
        <TabsContent value="maintenance" className="space-y-6 mt-6">
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
            {/* Scheduled Maintenance */}
            <div className="lg:col-span-2 space-y-6">
              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-calendar-check"></i>
                    المهام المجدولة
                  </CardTitle>
                  <CardDescription>مهام الصيانة المجدولة والمؤتمتة</CardDescription>
                </CardHeader>
                <CardContent>
                  <div className="overflow-x-auto">
                    <table className="w-full border-collapse border border-gray-200 dark:border-gray-700">
                      <thead>
                        <tr className="bg-gray-50 dark:bg-gray-800">
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-right">المهمة</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">النوع</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">الجدولة</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">آخر تشغيل</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">التالي</th>
                          <th className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">الحالة</th>
                        </tr>
                      </thead>
                      <tbody>
                        {[
                          { task: 'نسخ احتياطي للبيانات', type: 'backup', schedule: 'يومي - 2:00 ص', lastRun: 'اليوم 2:00 ص', nextRun: 'غدًا 2:00 ص', status: 'نشط' },
                          { task: 'تحسين قاعدة البيانات', type: 'optimization', schedule: 'أسبوعي - الأحد', lastRun: 'منذ 3 أيام', nextRun: 'بعد 4 أيام', status: 'نشط' },
                          { task: 'تنظيف ملفات السجل', type: 'cleanup', schedule: 'شهري', lastRun: 'منذ 15 يوم', nextRun: 'بعد 15 يوم', status: 'نشط' },
                          { task: 'فحص النظام', type: 'health', schedule: 'كل 6 ساعات', lastRun: 'منذ 4 ساعات', nextRun: 'بعد ساعتين', status: 'نشط' },
                          { task: 'تحديث الإحصائيات', type: 'stats', schedule: 'كل ساعة', lastRun: 'منذ 45 دقيقة', nextRun: 'بعد 15 دقيقة', status: 'نشط' }
                        ].map((task, index) => (
                          <tr key={index} className="hover:bg-gray-50 dark:hover:bg-gray-800">
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2">
                              <div className="flex items-center gap-2">
                                <i className={`bi ${task.type === 'backup' ? 'bi-archive' : task.type === 'optimization' ? 'bi-gear' : task.type === 'cleanup' ? 'bi-trash3' : task.type === 'health' ? 'bi-heart-pulse' : 'bi-graph-up'} text-blue-600`}></i>
                                {task.task}
                              </div>
                            </td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">
                              <Badge variant="outline">{task.type}</Badge>
                            </td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">{task.schedule}</td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">{task.lastRun}</td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">{task.nextRun}</td>
                            <td className="border border-gray-300 dark:border-gray-600 px-4 py-2 text-center">
                              <Badge variant="default" className="bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-100">
                                {task.status}
                              </Badge>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-tools"></i>
                    أدوات الصيانة
                  </CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {[
                      { name: 'تنظيف ملفات مؤقتة', icon: 'bi-brush', description: 'حذف الملفات المؤقتة وتنظيف المساحة' },
                      { name: 'إعادة تشغيل الخدمات', icon: 'bi-arrow-clockwise', description: 'إعادة تشغيل جميع الخدمات النظام' },
                      { name: 'فحص سلامة البيانات', icon: 'bi-check-circle', description: 'التحقق من سلامة قاعدة البيانات' },
                      { name: 'تحديث التبعيات', icon: 'bi-arrow-up-circle', description: 'تحديث المكتبات والتبعيات' },
                      { name: 'مراقبة الأداء', icon: 'bi-speedometer2', description: 'تحليل أداء النظام وتحسينه' },
                      { name: 'أمان النظام', icon: 'bi-shield-check', description: 'فحص الأمان وإصلاح الثغرات' }
                    ].map((tool, index) => (
                      <Button key={index} variant="outline" className="h-auto p-4 flex flex-col items-start gap-2">
                        <div className="flex items-center gap-2 w-full">
                          <i className={`${tool.icon} text-blue-600`}></i>
                          <span className="font-medium">{tool.name}</span>
                        </div>
                        <p className="text-sm text-muted-foreground text-right">{tool.description}</p>
                      </Button>
                    ))}
                  </div>
                </CardContent>
              </Card>
            </div>

            {/* System Health & Controls */}
            <div className="space-y-6">
              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-cpu"></i>
                    حالة النظام
                  </CardTitle>
                </CardHeader>
                <CardContent className="space-y-4">
                  <div className="space-y-3">
                    <div className="flex items-center justify-between">
                      <span className="text-sm">استخدام المعالج</span>
                      <span className="text-sm font-medium">{systemStats.cpuUsage}%</span>
                    </div>
                    <div className="w-full bg-gray-200 rounded-full h-2 dark:bg-gray-700">
                      <div className="bg-blue-600 h-2 rounded-full" style={{ width: `${systemStats.cpuUsage}%` }}></div>
                    </div>
                  </div>
                  <div className="space-y-3">
                    <div className="flex items-center justify-between">
                      <span className="text-sm">استخدام الذاكرة</span>
                      <span className="text-sm font-medium">{systemStats.memoryUsage}%</span>
                    </div>
                    <div className="w-full bg-gray-200 rounded-full h-2 dark:bg-gray-700">
                      <div className="bg-yellow-600 h-2 rounded-full" style={{ width: `${systemStats.memoryUsage}%` }}></div>
                    </div>
                  </div>
                  <div className="space-y-3">
                    <div className="flex items-center justify-between">
                      <span className="text-sm">استخدام القرص</span>
                      <span className="text-sm font-medium">{systemStats.diskUsage}%</span>
                    </div>
                    <div className="w-full bg-gray-200 rounded-full h-2 dark:bg-gray-700">
                      <div className="bg-green-600 h-2 rounded-full" style={{ width: `${systemStats.diskUsage}%` }}></div>
                    </div>
                  </div>
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-power"></i>
                    التحكم الطارئ
                  </CardTitle>
                </CardHeader>
                <CardContent className="space-y-3">
                  <Button variant="destructive" className="w-full" size="sm">
                    <i className="bi bi-exclamation-triangle w-4 h-4 ml-2"></i>
                    إيقاف طارئ للنظام
                  </Button>
                  <Button variant="outline" className="w-full" size="sm">
                    <i className="bi bi-arrow-clockwise w-4 h-4 ml-2"></i>
                    إعادة تشغيل النظام
                  </Button>
                  <Button variant="outline" className="w-full" size="sm">
                    <i className="bi bi-pause-circle w-4 h-4 ml-2"></i>
                    وضع الصيانة
                  </Button>
                  <Button variant="outline" className="w-full" size="sm">
                    <i className="bi bi-shield-slash w-4 h-4 ml-2"></i>
                    الوضع الآمن
                  </Button>
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle className="flex items-center gap-2">
                    <i className="bi bi-clock-history"></i>
                    آخر العمليات
                  </CardTitle>
                </CardHeader>
                <CardContent className="space-y-3">
                  {[
                    { action: 'نسخ احتياطي', time: 'منذ 2 ساعة', status: 'مكتمل' },
                    { action: 'تحسين قاعدة البيانات', time: 'منذ 6 ساعات', status: 'مكتمل' },
                    { action: 'تنظيف الملفات', time: 'أمس', status: 'مكتمل' },
                    { action: 'فحص الأمان', time: 'منذ يومين', status: 'مكتمل' }
                  ].map((operation, index) => (
                    <div key={index} className="flex items-center justify-between p-2 bg-gray-50 dark:bg-gray-800 rounded">
                      <div>
                        <div className="text-sm font-medium">{operation.action}</div>
                        <div className="text-xs text-muted-foreground">{operation.time}</div>
                      </div>
                      <Badge variant="default" className="bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-100 text-xs">
                        {operation.status}
                      </Badge>
                    </div>
                  ))}
                </CardContent>
              </Card>
            </div>
          </div>
        </TabsContent>
      </Tabs>
    </div>
  );
}