                                <p className="text-xs text-muted-foreground">{api.requests} طلب</p>
                              </div>
                            </div>
                            <div className="text-right">
                              <p className="font-bold">{api.avgTime}</p>
                              <Badge className={`text-xs ${
                                api.status === 'excellent' ? 'bg-green-100 text-green-700' :
                                api.status === 'good' ? 'bg-blue-100 text-blue-700' :
                                api.status === 'warning' ? 'bg-orange-100 text-orange-700' : 'bg-red-100 text-red-700'
                              }`}>
                                {api.status === 'excellent' ? 'ممتاز' :
                                 api.status === 'good' ? 'جيد' :
                                 api.status === 'warning' ? 'بطيء' : 'خطأ'}
                              </Badge>
                            </div>
                          </div>
                        ))}
                      </div>
                    </CardContent>
